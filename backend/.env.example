PORT=4000
NODE_ENV=development
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-public-url.example.com/api/mpesa/callback

# Router credentials — one block per router.
# Set credentialsKey on the router record to the prefix used here (e.g. "ROUTER_MAIN").
# The backend will read <KEY>_USER and <KEY>_PASS from env — never from the browser.
#
# Example for a router with credentialsKey="ROUTER_MAIN":
ROUTER_MAIN_USER=admin
ROUTER_MAIN_PASS=your-router-password

# Example for a second router with credentialsKey="ROUTER_BRANCH":
# ROUTER_BRANCH_USER=admin
# ROUTER_BRANCH_PASS=branch-router-password

# Set NODE_TLS_REJECT_UNAUTHORIZED=0 only if your routers use self-signed HTTPS certs.
# Never set this in production without understanding the security implications.
# NODE_TLS_REJECT_UNAUTHORIZED=0
